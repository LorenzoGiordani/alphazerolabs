{
  "name": "lux-paper-cron",
  "main": "src/index.js",
  "compatibility_date": "2025-06-01",
  "observability": { "enabled": true },
  // "10 * * * *" = paper-run completo orario; "*/3 * * * *" = monitor TP/SL real-time
  // (dispatcha paper-exits SOLO se un livello è sfiorato)
  "triggers": { "crons": ["10 * * * *", "*/3 * * * *"] }
}
